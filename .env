# ════════════════════════════════════════════════════════════
# CONFIGURARE ASISTENT AI - OPENAI
# ════════════════════════════════════════════════════════════

# 🔑 API KEY OpenAI
# Obținuți de la: https://platform.openai.com/api-keys
# Format: sk-proj-... (o lungă cheie de caractere)
# ⚠️ NICIODATĂ NU POSTA ACEST FIȘIER ONLINE!


# 🖥️ PORT Server
# Unde funcționează backend-ul
# Implicit: 3000
# Dacă 3000 e ocupat, schimbă la: 3001, 3002, etc.

PORT=3000

# 🌍 ENVIRONMENT
# Moduri: development, production
# Development = mai mult debug info
# Production = minimal logs

NODE_ENV=development

# ════════════════════════════════════════════════════════════
# INSTRUCȚIUNI SETUP
# ════════════════════════════════════════════════════════════

# 1. CREEAZĂ FIȘIERUL .env (NU .env.example!)
#    - Copiază acest fișier
#    - Redenumește-l în: .env
#    - Pune-l în rădăcina proiectului

# 2. ADAUGĂ API KEY-UL TĂU
#    - Mergi pe: https://platform.openai.com/api-keys
#    - Copiază cheia (va fi o lungă secvență)
#    - Înlocuiește: sk-proj-YOUR_API_KEY_HERE

# 3. SALVEAZĂ FIȘIERUL

# 4. PORNIRE BACKEND
#    npm install
#    npm start

# ════════════════════════════════════════════════════════════
# VERIFICARE
# ════════════════════════════════════════════════════════════

# Dacă e ok, vei vedea:
# ✅ "🤖 AI Server funcționează pe http://localhost:3000"
# ✅ "📝 Endpoint chat: POST http://localhost:3000/api/chat"

